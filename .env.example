# ---- LLM Provider ----
# 'ollama' (default, local Qwen3) or 'openai' (cloud)
LLM_PROVIDER=ollama

# Model name (default: qwen3 for Ollama, gpt-4o for OpenAI)
LLM_MODEL=qwen3

# Base URL (default: http://localhost:11434/v1 for Ollama)
# LLM_BASE_URL=http://localhost:11434/v1

# Only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-api-key-here

# ---- Whitelabel Branding ----
# All optional. Defaults to "LLM Wiki" branding if not set.
# NEXT_PUBLIC_BRAND_APP_NAME=My Wiki
# NEXT_PUBLIC_BRAND_TAGLINE=Knowledge Base
# NEXT_PUBLIC_BRAND_META_TITLE=My Wiki
# NEXT_PUBLIC_BRAND_META_DESCRIPTION=My personal knowledge base
# NEXT_PUBLIC_BRAND_LOGO_URL=/logo.svg
# NEXT_PUBLIC_BRAND_FAVICON_URL=/favicon.ico
# NEXT_PUBLIC_BRAND_PRIMARY_COLOR=#3b82f6
# NEXT_PUBLIC_BRAND_FOOTER_TEXT=Powered by MyCompany
# NEXT_PUBLIC_BRAND_FOOTER_LINK=https://example.com
# NEXT_PUBLIC_BRAND_SHOW_KARPATHY_CREDIT=true
